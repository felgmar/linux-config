#!/bin/sh

wine_processes="$(ps -e | pgrep exe | awk '{print $1}')"
wine_process_count="$(echo "$wine_processes" | wc -l)"

if test "${wine_process_count}" -gt 0
then
    for f in ${wine_processes}
    do
        echo "Killing process ID $f..." && kill -9 "$f"
    done
fi

echo "Wine is not running!"
exit 2
